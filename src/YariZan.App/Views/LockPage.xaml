<UserControl x:Class="YariZan.App.Views.LockPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="{DynamicResource ShabnamFont}"
             Background="Transparent">

    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="720" CornerRadius="14" BorderBrush="{StaticResource LeatherDarkBrush}"
                BorderThickness="3" Background="{StaticResource ParchmentBrushGradient}">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.6" ShadowDepth="6" />
            </Border.Effect>

            <Grid Margin="36,28">
                <Border BorderBrush="{StaticResource GoldBrush}" BorderThickness="2" CornerRadius="6"
                        Margin="-12" Opacity="0.5" />

                <StackPanel>
                    <TextBlock Text="قفل کتاب" FontFamily="{DynamicResource ShabnamBoldFont}"
                               FontSize="36" Foreground="{StaticResource LeatherDarkBrush}"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="برای فعال‌سازی برنامه، شناسهٔ دستگاه را برای پشتیبانی ارسال کنید و سریالی که برایتان فرستاده می‌شود را در کادر پایین وارد نمایید."
                               FontSize="15" TextWrapping="Wrap" TextAlignment="Center" Margin="20,12,20,0"
                               Foreground="{StaticResource InkBrush}" LineHeight="26" />

                    <!-- HWID -->
                    <TextBlock Text="شناسهٔ دستگاه" FontSize="14" FontFamily="{DynamicResource ShabnamBoldFont}"
                               Foreground="{StaticResource LeatherDarkBrush}" HorizontalAlignment="Center"
                               Margin="0,18,0,6" />
                    <Border Background="#FAEFCF" BorderBrush="{StaticResource LeatherBrush}" BorderThickness="1.5"
                            CornerRadius="6" Padding="12,8" Margin="20,0">
                        <DockPanel LastChildFill="True" FlowDirection="LeftToRight">
                            <Button x:Name="CopyHwidBtn" DockPanel.Dock="Right" Content="کپی"
                                    Width="64" Height="34" Style="{StaticResource GoldButton}"
                                    FontSize="13" Padding="0" Click="CopyHwid_Click"
                                    FlowDirection="RightToLeft" />
                            <TextBlock x:Name="HwidText" Style="{StaticResource HwidBox}"
                                       FlowDirection="LeftToRight" TextAlignment="Center" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                        </DockPanel>
                    </Border>

                    <!-- Support / contact card -->
                    <Border Margin="20,18,20,0" CornerRadius="8" Padding="18,14"
                            Background="#22000000" BorderBrush="{StaticResource LeatherBrush}" BorderThickness="1.5">
                        <StackPanel>
                            <TextBlock Text="شمارهٔ پشتیبانی" FontFamily="{DynamicResource ShabnamBoldFont}"
                                       FontSize="14" Foreground="{StaticResource LeatherDarkBrush}"
                                       HorizontalAlignment="Center" />

                            <TextBlock x:Name="PhoneText" Text="0918-876-4024"
                                       FontFamily="Consolas, Tahoma" FontSize="26" FontWeight="Bold"
                                       Foreground="{StaticResource LeatherDarkBrush}"
                                       FlowDirection="LeftToRight" TextAlignment="Center"
                                       HorizontalAlignment="Center" Margin="0,4,0,0" />

                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="13" LineHeight="22"
                                       Foreground="{StaticResource InkBrush}" Margin="0,8,0,0"
                                       Text="شناسهٔ دستگاه را با پیامی که در زیر آماده شده برای این شماره ارسال کنید. زمان دریافت پاسخ بین ۱۵ دقیقه تا ۸ ساعت می‌باشد." />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Content="کپی پیام آماده" Style="{StaticResource GoldButton}"
                                        FontSize="14" MinHeight="34" Padding="16,6" MinWidth="160"
                                        Click="CopyMessage_Click" Margin="4,0" />
                                <Button Content="کپی شماره" Style="{StaticResource GoldButton}"
                                        FontSize="14" MinHeight="34" Padding="16,6" MinWidth="120"
                                        Click="CopyPhone_Click" Margin="4,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Serial input -->
                    <TextBlock Text="سریال دریافتی" FontSize="14" FontFamily="{DynamicResource ShabnamBoldFont}"
                               Foreground="{StaticResource LeatherDarkBrush}" HorizontalAlignment="Center"
                               Margin="0,20,0,6" />
                    <TextBox x:Name="SerialBox" Style="{StaticResource SerialBox}" Margin="20,0" />

                    <TextBlock x:Name="StatusText" HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="20,10,20,0"
                               FontSize="13" Foreground="#8B0000" />

                    <!-- RTL StackPanel: source-first child renders rightmost. minimize before خروج → minimize is visually right of خروج. -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Button Content="فعال‌سازی" Style="{StaticResource GoldButton}" MinWidth="150"
                                Click="Activate_Click" Margin="5,0" />
                        <Button Content="بازگشت" Style="{StaticResource GoldButton}" MinWidth="110"
                                Click="Cancel_Click" Margin="5,0" />
                        <Button Style="{StaticResource MinimizeButton}" Click="Minimize_Click" Margin="5,0" />
                        <Button Content="خروج" Style="{StaticResource ExitButton}" MinWidth="100"
                                Click="Exit_Click" Margin="5,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
