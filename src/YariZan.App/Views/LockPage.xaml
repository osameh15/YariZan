<UserControl x:Class="YariZan.App.Views.LockPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="{DynamicResource ShabnamFont}"
             Background="Transparent">

    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="640" Height="640" CornerRadius="14" BorderBrush="{StaticResource LeatherDarkBrush}"
                BorderThickness="3" Background="{StaticResource ParchmentBrushGradient}">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.6" ShadowDepth="6" />
            </Border.Effect>

            <Grid Margin="40">
                <Border BorderBrush="{StaticResource GoldBrush}" BorderThickness="2" CornerRadius="6"
                        Margin="-12" Opacity="0.5" />

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="قفل کتاب" FontFamily="{DynamicResource ShabnamBoldFont}"
                               FontSize="40" Foreground="{StaticResource LeatherDarkBrush}"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="برای فعال‌سازی، شناسهٔ دستگاه را برای فروشنده ارسال کنید و سریال دریافتی را وارد نمایید."
                               FontSize="16" TextWrapping="Wrap" TextAlignment="Center" Margin="20,18,20,0"
                               Foreground="{StaticResource InkBrush}" />

                    <TextBlock Text="شناسهٔ دستگاه" FontSize="15" FontFamily="{DynamicResource ShabnamBoldFont}"
                               Foreground="{StaticResource LeatherDarkBrush}" HorizontalAlignment="Center" Margin="0,28,0,8" />
                    <Border Background="#FAEFCF" BorderBrush="{StaticResource LeatherBrush}" BorderThickness="1.5"
                            CornerRadius="6" Padding="12,8" Margin="60,0">
                        <DockPanel LastChildFill="True">
                            <Button x:Name="CopyHwidBtn" DockPanel.Dock="Left" Content="کپی" Width="64" Height="34"
                                    Style="{StaticResource GoldButton}" FontSize="14" Padding="0"
                                    Click="CopyHwid_Click" />
                            <TextBlock x:Name="HwidText" Style="{StaticResource HwidBox}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </DockPanel>
                    </Border>

                    <TextBlock Text="سریال" FontSize="15" FontFamily="{DynamicResource ShabnamBoldFont}"
                               Foreground="{StaticResource LeatherDarkBrush}" HorizontalAlignment="Center" Margin="0,24,0,8" />
                    <TextBox x:Name="SerialBox" Style="{StaticResource SerialBox}" Margin="60,0"
                             FlowDirection="LeftToRight" />

                    <TextBlock x:Name="StatusText" HorizontalAlignment="Center" Margin="0,12,0,0"
                               FontSize="14" Foreground="#8B0000" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
                        <Button Content="فعال‌سازی" Style="{StaticResource GoldButton}" MinWidth="160"
                                Click="Activate_Click" Margin="8,0" />
                        <Button Content="بازگشت" Style="{StaticResource GoldButton}" MinWidth="120"
                                Click="Cancel_Click" Margin="8,0" />
                        <Button Content="خروج" Style="{StaticResource ExitButton}" MinWidth="100"
                                Click="Exit_Click" Margin="8,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
