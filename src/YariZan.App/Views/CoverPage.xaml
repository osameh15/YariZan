<UserControl x:Class="YariZan.App.Views.CoverPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="{DynamicResource ShabnamFont}"
             Foreground="{StaticResource GoldBrush}"
             Background="Transparent">

    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="520" Height="640">

            <Rectangle Fill="#33000000" RadiusX="14" RadiusY="14" Margin="14,30,-14,-14" />

            <Border CornerRadius="10" BorderThickness="3" BorderBrush="{StaticResource LeatherDarkBrush}"
                    Background="{StaticResource LeatherCoverBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.6" ShadowDepth="6" />
                </Border.Effect>

                <Grid>
                    <Border CornerRadius="6" BorderThickness="2" BorderBrush="{StaticResource GoldBrush}"
                            Margin="20" />

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="YariZan" FontFamily="Georgia, Tahoma" FontSize="64" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"
                                   FlowDirection="LeftToRight">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.8" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <Image Source="/Resources/logo.png" Width="220" Height="220" Margin="0,12,0,0"
                               Stretch="Uniform" />
                        <TextBlock x:Name="VersionText" FontSize="16"
                                   Foreground="{StaticResource GoldBrush}" Opacity="0.85"
                                   HorizontalAlignment="Center" Margin="0,18,0,0" />
                        <TextBlock Text="برای ورود کلیک کنید" FontFamily="{DynamicResource ShabnamFont}"
                                   FontSize="18" Foreground="{StaticResource GoldBrush}" Opacity="0.7"
                                   HorizontalAlignment="Center" Margin="0,28,0,0" />
                    </StackPanel>

                    <Rectangle HorizontalAlignment="Left" Width="14" Fill="{StaticResource LeatherDarkBrush}" />

                    <Path Stroke="{StaticResource GoldBrush}" StrokeThickness="1.5" Opacity="0.5"
                          HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,32,0,0"
                          Data="M -60,0 C -30,-20 30,-20 60,0 M -60,8 C -30,-12 30,-12 60,8" />
                    <Path Stroke="{StaticResource GoldBrush}" StrokeThickness="1.5" Opacity="0.5"
                          HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,32"
                          Data="M -60,0 C -30,-20 30,-20 60,0 M -60,8 C -30,-12 30,-12 60,8" />
                </Grid>
            </Border>

            <Grid.InputBindings>
                <MouseBinding Gesture="LeftClick" Command="{Binding OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Grid.InputBindings>
        </Grid>

        <TextBlock Text="© YariZan — یاریزان" FontFamily="{DynamicResource ShabnamFont}" FontSize="12"
                   Foreground="{StaticResource GoldBrush}" Opacity="0.6"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16" />
    </Grid>
</UserControl>
