<UserControl x:Class="YariZan.App.Views.InfoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="{DynamicResource ShabnamFont}"
             Background="Transparent">

    <Viewbox Stretch="Uniform">
        <Grid Width="1100" Height="680">

            <Border CornerRadius="14" BorderBrush="{StaticResource LeatherDarkBrush}"
                    BorderThickness="3" Background="{StaticResource LeatherCoverBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.6" ShadowDepth="6" />
                </Border.Effect>
            </Border>

            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource ParchmentBrushGradient}" CornerRadius="6"
                        Margin="6,4,0,4">
                    <Grid Margin="40">
                        <StackPanel VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/icon.png"
                                   Width="260" Height="260" Stretch="Uniform" />
                            <TextBlock Text="یاریزان" FontFamily="{DynamicResource ShabnamBoldFont}"
                                       FontSize="56" Foreground="{StaticResource LeatherDarkBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" />
                            <TextBlock Text="مجموعه بازی‌های آموزشی" FontSize="20"
                                       Foreground="{StaticResource LeatherBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Column="0" Grid.ColumnSpan="2" Width="6" Fill="{StaticResource LeatherDarkBrush}"
                           HorizontalAlignment="Center" Margin="0,4" />

                <Border Grid.Column="1" Background="{StaticResource ParchmentBrushGradient}" CornerRadius="6"
                        Margin="0,4,6,4">
                    <Grid Margin="40">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="درباره" FontFamily="{DynamicResource ShabnamBoldFont}"
                                       FontSize="36" Foreground="{StaticResource LeatherDarkBrush}"
                                       HorizontalAlignment="Center" />

                            <TextBlock FontSize="18" Foreground="{StaticResource InkBrush}"
                                       TextAlignment="Justify" TextWrapping="Wrap" Margin="0,28,0,0"
                                       LineHeight="32">
                                <Run Text="یاریزان مجموعه‌ای از بازی‌های آموزشی است که برای کلاس‌های اول تا ششم ابتدایی طراحی شده. هر صفحه از کتاب شامل 6 بازی است؛ با چرخاندن صفحه به بازی‌های دیگر دسترسی پیدا می‌کنید." />
                            </TextBlock>

                            <Border Margin="0,28,0,0" Padding="18,14" CornerRadius="6"
                                    Background="#22000000" BorderBrush="{StaticResource LeatherBrush}" BorderThickness="1.5">
                                <StackPanel>
                                    <TextBlock Text="پدیدآورنده" FontFamily="{DynamicResource ShabnamBoldFont}"
                                               FontSize="18" Foreground="{StaticResource LeatherDarkBrush}" />
                                    <TextBlock Text="استودیوی یاریزان" FontSize="16"
                                               Foreground="{StaticResource InkBrush}" Margin="0,4,0,0" />
                                    <TextBlock x:Name="VersionText" FontSize="14"
                                               Foreground="{StaticResource LeatherBrush}" Margin="0,8,0,0" />
                                    <TextBlock x:Name="TrialBanner" Visibility="Collapsed"
                                               FontFamily="{DynamicResource ShabnamBoldFont}" FontSize="14"
                                               Foreground="#A3501F" TextAlignment="Center"
                                               Margin="0,10,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <StackPanel HorizontalAlignment="Stretch" Margin="0,28,0,0">
                                <Button Content="ورود به کتاب بازی‌ها" Style="{StaticResource GoldButton}"
                                        HorizontalAlignment="Stretch" Click="Next_Click" Margin="0,0,0,10" />
                                <!-- RTL Grid: column 0 renders on the visual RIGHT.
                                     Visual layout (right→left): minimize | خروج | بازگشت. -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="بازگشت" Style="{StaticResource GoldButton}"
                                            HorizontalAlignment="Stretch" Click="Back_Click" />
                                    <Button Grid.Column="2" Style="{StaticResource MinimizeButton}"
                                            Click="Minimize_Click" />
                                    <Button Grid.Column="4" Content="خروج" Style="{StaticResource ExitButton}"
                                            HorizontalAlignment="Stretch" Click="Exit_Click" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</UserControl>
