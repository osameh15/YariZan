<UserControl x:Class="YariZan.App.Views.GamesBookPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="{DynamicResource ShabnamFont}"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="GameTile" TargetType="Button">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{DynamicResource ShabnamBoldFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource LeatherDarkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" BorderBrush="{StaticResource LeatherBrush}"
                                BorderThickness="1.5" Background="#FBEFCB">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" Opacity="0.25" ShadowDepth="2" />
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="6" CornerRadius="6" ClipToBounds="True"
                                        Background="#22000000">
                                    <Image Source="{Binding ImagePath, RelativeSource={RelativeSource AncestorType=Button}}"
                                           Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Grid.Row="1" Text="{Binding GameName, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Center" Margin="6,2,6,8" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF6D8" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource GoldBrush}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GradeButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="FontFamily" Value="{DynamicResource ShabnamBoldFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource LeatherDarkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="22" BorderBrush="{StaticResource LeatherDarkBrush}"
                                BorderThickness="2" Background="#F1E2B7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource GoldBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource GoldBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1180" Height="720">

            <Border CornerRadius="14" BorderBrush="{StaticResource LeatherDarkBrush}"
                    BorderThickness="3" Background="{StaticResource LeatherCoverBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.6" ShadowDepth="6" />
                </Border.Effect>
            </Border>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="6,2,6,8">
                    <TextBlock Text="کتاب بازی‌ها" FontFamily="{DynamicResource ShabnamBoldFont}"
                               FontSize="22" Foreground="{StaticResource GoldBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0" />

                    <StackPanel x:Name="GradePicker" Orientation="Horizontal" HorizontalAlignment="Center" />

                    <Button Content="بازگشت" Style="{StaticResource GoldButton}" FontSize="14" Padding="14,6"
                            HorizontalAlignment="Left" Click="Back_Click" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource ParchmentBrushGradient}"
                            CornerRadius="6" Margin="6,0,0,0">
                        <UniformGrid x:Name="LeftPage" Rows="3" Columns="3" Margin="14" />
                    </Border>

                    <Rectangle Grid.Column="0" Grid.ColumnSpan="2" Width="6"
                               Fill="{StaticResource LeatherDarkBrush}" HorizontalAlignment="Center" />

                    <Border Grid.Column="1" Background="{StaticResource ParchmentBrushGradient}"
                            CornerRadius="6" Margin="0,0,6,0">
                        <UniformGrid x:Name="RightPage" Rows="3" Columns="3" Margin="14" />
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="6,8,6,2">
                    <Button Content="◄ صفحهٔ قبل" Style="{StaticResource GoldButton}" FontSize="14"
                            Padding="14,6" HorizontalAlignment="Right" Click="PrevPage_Click" />
                    <TextBlock x:Name="PageIndicator" FontFamily="{DynamicResource ShabnamBoldFont}"
                               FontSize="16" Foreground="{StaticResource GoldBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Button Content="صفحهٔ بعد ►" Style="{StaticResource GoldButton}" FontSize="14"
                            Padding="14,6" HorizontalAlignment="Left" Click="NextPage_Click" />
                </Grid>
            </Grid>
        </Grid>
    </Viewbox>
</UserControl>
